datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ==========================================
// ENUMS (Types stricts pour la cohérence)
// ==========================================

enum Role {
  SUPER_ADMIN
  BAILLEUR
  GERANT
  LOCATAIRE
  PRESTATAIRE
}
enum TicketStatus {
  OUVERT
  ASSIGNE
  EN_COURS
  RESOLU
  CLOTURE
}

enum UrgencyLevel {
  FAIBLE
  MOYEN
  CRITIQUE
}

enum PaymentStatus {
  EN_ATTENTE
  PARTIEL    // Paiement partiel en cours (tranches)
  PAYE
  ECHOUE
  REJETE
}

enum ExpenseCategory {
  PRESTATAIRE      // Paiement d'un prestataire (réparation, dépannage)
  PERSONNEL        // Salaire gardien, concierge, agent d'entretien
  FOURNITURES      // Matériaux, équipements, consommables
  CHARGES_COMMUNES // Eau, électricité, ascenseur parties communes
  ASSURANCE        // Assurance du bien
  TAXE_IMPOT       // Taxe foncière, impôts locaux
  AUTRE
}

enum ExpenseStatus {
  EN_ATTENTE // Dépense créée, paiement pas encore effectué
  PAYEE      // Paiement confirmé
  ANNULEE    // Annulée avant paiement
}

enum PropertyType {
  APPARTEMENT
  STUDIO
  VILLA
  MAGASIN
  AUTRE
}

enum CotisationStatut {
  ACTIF
  SUSPENDU
  CLOTURE
}

// ==========================================
// MODÈLES (Tables)
// ==========================================

model User {
  id                   String    @id @default(uuid())
  email                String    @unique
  nom                  String
  prenom               String
  telephone            String?
  role                 Role      @default(LOCATAIRE)
  password             String
  refreshToken         String?
  passwordResetToken   String?
  passwordResetExpiry  DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  // Relations
  notifications         Notification[] @relation("NotificationsRecues")
  notificationsEnvoyees Notification[] @relation("NotificationsEnvoyees")
  ownedProperties Property[]   @relation("BailleurProperties") // Les biens qu'il possède (si Bailleur)
  managedProperties Property[] @relation("GerantProperties")   // Les biens qu'il gère (si Gérant)
  contracts       Contract[]   // Les contrats signés (si Locataire)
  reportedTickets Ticket[]     @relation("LocataireTickets")   // Pannes signalées
  assignedTickets Ticket[]     @relation("PrestataireTickets") // Pannes à réparer (si Prestataire)
  payments        Payment[]    // Paiements de loyer effectués
  depensesPayees  Expense[]    @relation("DepensesPayees")     // Dépenses initiées (si Gérant/Bailleur)
  depensesRecues  Expense[]    @relation("DepensesRecues")     // Dépenses reçues (si Prestataire/Personnel)
  auditLogs       AuditLog[]   // Actions tracées
  groupesCrees    CotisationGroupe[] @relation("GroupesCrees") // Groupes de cotisation créés
  memberships     CotisationMembre[] @relation("MembresGroupes") // Participations aux cotisations

  @@map("users")
}

model Property {
  id          String       @id @default(uuid())
  titre       String       // ex: "Villa Duplex Chic"
  description String?
  adresse     String
  ville       String
  type        PropertyType @default(APPARTEMENT)
  loyerDeBase Float        // Montant hors charges
  charges     Float        @default(0)
  estOccupe   Boolean      @default(false)
  
  // Relations
  bailleurId  String
  bailleur    User         @relation("BailleurProperties", fields: [bailleurId], references: [id])
  gerantId    String?
  gerant      User?        @relation("GerantProperties", fields: [gerantId], references: [id])
  
  contracts         Contract[]
  tickets           Ticket[]
  expenses          Expense[]
  cotisationGroupes CotisationGroupe[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@map("properties")
}

model Contract {
  id          String    @id @default(uuid())
  dateDebut   DateTime
  dateFin     DateTime?
  loyerTotal  Float     // Loyer de base + charges au moment de la signature
  estActif    Boolean   @default(true)

  // Relations
  propertyId  String
  property    Property  @relation(fields: [propertyId], references: [id])
  locataireId String
  locataire   User      @relation(fields: [locataireId], references: [id])
  
  payments    Payment[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@map("contracts")
}

model Ticket {
  id           String       @id @default(uuid())
  titre        String
  description  String
  photos       String[]     // Stockage des URLs des images
  urgence      UrgencyLevel @default(MOYEN)
  statut       TicketStatus @default(OUVERT)

  // Relations
  propertyId   String
  property     Property     @relation(fields: [propertyId], references: [id])
  locataireId  String
  locataire    User         @relation("LocataireTickets", fields: [locataireId], references: [id])
  prestataireId String?
  prestataire  User?        @relation("PrestataireTickets", fields: [prestataireId], references: [id])

  expense      Expense?     // Dépense liée à ce ticket (intervention d'un prestataire)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("tickets")
}

model Payment {
  id            String        @id @default(uuid())
  montant       Float
  datePaiement  DateTime?
  periode       String        // ex: "06-2026" pour Juin 2026
  statut          PaymentStatus    @default(EN_ATTENTE)
  referenceId     String?          @unique // Référence de la passerelle (Wave, Orange Money…)
  recuUrl       String?       // Lien vers la quittance PDF

  // Relations
  contractId    String
  contract      Contract      @relation(fields: [contractId], references: [id])
  locataireId   String
  locataire     User          @relation(fields: [locataireId], references: [id])

  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@map("payments")
}

model Expense {
  id               String          @id @default(uuid())
  titre            String          // ex: "Réparation plomberie Juin", "Salaire gardien"
  description      String?
  montant          Float
  date             DateTime        @default(now()) // Date effective de la dépense
  categorie        ExpenseCategory
  statut           ExpenseStatus   @default(EN_ATTENTE)
  beneficiaireNom  String          // Nom du bénéficiaire (toujours renseigné)
  referenceId      String?         // Référence du virement / chèque / mobile money
  justificatifUrl  String?         // URL facture ou reçu (Cloudinary)

  // Relations
  payeurId         String
  payeur           User            @relation("DepensesPayees", fields: [payeurId], references: [id])
  beneficiaireId   String?         // Si le bénéficiaire est un utilisateur du système
  beneficiaire     User?           @relation("DepensesRecues", fields: [beneficiaireId], references: [id])
  propertyId       String?         // Bien concerné (optionnel pour dépenses globales)
  property         Property?       @relation(fields: [propertyId], references: [id])
  ticketId         String?         @unique // Dépense liée à une intervention (optionnel)
  ticket           Ticket?         @relation(fields: [ticketId], references: [id])
  cotisationGroupeId String?       // Décaissement depuis un fonds de cotisation
  cotisationGroupe   CotisationGroupe? @relation(fields: [cotisationGroupeId], references: [id])

  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@map("expenses")
}

model AuditLog {
  id        String   @id @default(uuid())
  action    String   // ex: "TICKET_STATUS_UPDATE", "PAYMENT_RECEIVED"
  table     String   // ex: "Ticket", "Payment"
  enregistrementId String // L'ID de la ligne modifiée
  details   Json     // Stocke l'état avant/après ou des métadonnées
  ipAdresse String?
  userAgent String?

  // Relations
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@map("audit_logs")
}

enum NotificationType {
  // Tickets
  TICKET_OUVERT           // Nouveau ticket signalé
  TICKET_STATUT_CHANGE    // Statut d'un ticket mis à jour
  NOUVEAU_TICKET_ASSIGNE  // Un ticket vous a été assigné (prestataire)
  TICKET_RESOLU           // Ticket marqué comme résolu
  // Paiements
  LOYER_DISPONIBLE        // Avis d'échéance disponible
  PAIEMENT_VALIDE         // Paiement confirmé
  PAIEMENT_REJETE         // Paiement rejeté
  PAIEMENT_ECHOUE         // Paiement échoué
  RAPPEL_IMPAYE           // Rappel loyer en attente
  // Contrats
  CONTRAT_CREE            // Nouveau contrat signé
  CONTRAT_RESILIE         // Contrat résilié
  // Dépenses
  DEPENSE_CREEE           // Nouvelle dépense enregistrée
  DEPENSE_PAYEE           // Dépense confirmée payée
  // Cotisations
  COTISATION_DUE              // Rappel : cotisation du mois à payer
  COTISATION_PAYEE            // Confirmation de réception du paiement
  COTISATION_NOUVEAU_GROUPE   // Ajout à un nouveau groupe de cotisation
  // Général
  MESSAGE_DIRECT          // Message direct entre acteurs
  SYSTEME                 // Notification système générale
}

model Notification {
  id          String           @id @default(uuid())
  titre       String
  message     String
  type        NotificationType
  estLu       Boolean          @default(false)

  // Destinataire (obligatoire)
  userId      String
  user        User             @relation("NotificationsRecues", fields: [userId], references: [id], onDelete: Cascade)

  // Expéditeur (null = notification système)
  expediteurId String?
  expediteur   User?           @relation("NotificationsEnvoyees", fields: [expediteurId], references: [id], onDelete: SetNull)

  createdAt   DateTime         @default(now())

  @@map("notifications")
}

// ==========================================
// COTISATIONS COMMUNES
// ==========================================

model CotisationGroupe {
  id               String           @id @default(uuid())
  nom              String           // "Charges Résidence Les Palmiers Bât A"
  description      String?
  montantParMembre Float            // Montant mensuel par locataire
  statut           CotisationStatut @default(ACTIF)

  // Bien/immeuble concerné (optionnel)
  propertyId       String?
  property         Property?        @relation(fields: [propertyId], references: [id])

  // Créateur du groupe (gestionnaire ou bailleur)
  createurId       String
  createur         User             @relation("GroupesCrees", fields: [createurId], references: [id])

  membres          CotisationMembre[]
  contributions    Contribution[]
  decaissements    Expense[]        // Dépenses payées via ce fonds

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@map("cotisation_groupes")
}

model CotisationMembre {
  id           String           @id @default(uuid())
  estTresorier Boolean          @default(false)  // Un seul trésorier actif par groupe
  estActif     Boolean          @default(true)
  dateAdhesion DateTime         @default(now())

  groupeId     String
  groupe       CotisationGroupe @relation(fields: [groupeId], references: [id], onDelete: Cascade)
  locataireId  String
  locataire    User             @relation("MembresGroupes", fields: [locataireId], references: [id])

  contributions Contribution[]

  @@unique([groupeId, locataireId])
  @@map("cotisation_membres")
}

model Contribution {
  id           String        @id @default(uuid())
  montant      Float
  periode      String        // "06-2026"
  statut       PaymentStatus @default(EN_ATTENTE)
  datePaiement DateTime?
  referenceId  String?       @unique // Référence mobile money
  recuUrl      String?       // Preuve de paiement (Cloudinary)

  montantPaye  Float         @default(0)  // Cumul des tranches versées

  groupeId     String
  groupe       CotisationGroupe @relation(fields: [groupeId], references: [id])
  membreId     String
  membre       CotisationMembre @relation(fields: [membreId], references: [id])

  tranches     TranchePaiement[]

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([groupeId, membreId, periode])
  @@map("contributions")
}

model TranchePaiement {
  id             String       @id @default(uuid())
  montant        Float
  datePaiement   DateTime     @default(now())
  referenceId    String?      @unique // Référence mobile money de cette tranche
  recuUrl        String?      // Preuve de paiement (Cloudinary)

  contributionId String
  contribution   Contribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)

  createdAt      DateTime     @default(now())

  @@map("tranches_paiement")
}